.venv/
.venv-voice/
__pycache__/
*.pyc
*.egg-info/
.DS_Store
build/
dist/
# downloaded model caches
models/
.cache/
# generated app bundle (recreate with scripts/make_app.sh)
Winter.app/
# only the built-in "default" character ships — characters you create, with
# their own sprites and voice clips, stay local to your machine
config/characters/*
!config/characters/default/
# per-user runtime state — Winter recreates settings.yaml from defaults
config/settings.yaml
# Claude Code's per-machine local settings
.claude/settings.local.json
# logs
winter.log
*.log
